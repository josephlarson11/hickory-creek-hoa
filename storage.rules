rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isBoardMember() {
      return signedIn() && firestore.get(/databases/(default)/documents/boardUsers/$(request.auth.token.email)).data.active == true;
    }

    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isBoardMember();
    }

    match /resident-submissions/{allPaths=**} {
      allow create: if request.resource.size < 10 * 1024 * 1024;
      allow read, update, delete: if isBoardMember();
    }

    match /board-private/{allPaths=**} {
      allow read, write: if isBoardMember();
    }
  }
}
